$item replace entity @s enderchest.$(offset) with player_head[profile="$(owner)", custom_name=$(name), lore=[$(description), "", [{"text":"0", color:green, italic:false}, {"text": " playing", color:gray, italic:false}], [{"text": "$(votes)", color:green, italic:false}, {text:" votes, ", color:gray, italic:false}, {text:"$(visits)", color:green, italic:false}, {text:" visits", color:gray, italic:false}], [{text:"by ", color:gray, italic: false}, $(formatted)]], custom_data={custom_ui:1b, world:1b, world_id:$(world_id)}, tooltip_display={hidden_components:["profile"]}]